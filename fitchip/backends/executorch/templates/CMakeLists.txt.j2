# Generated by FitChip v{{ fitchip_version }} for {{ target.display_name }}.
#
# Configure with the bundled bare-metal toolchain file:
#   cmake -B build -DCMAKE_TOOLCHAIN_FILE=cmake/arm-none-eabi.cmake
#   cmake --build build
#
# This builds `{{ project_name }}` (static library: embedded program + runner)
# and `{{ project_name }}_example` (a reference executable). Linking a real
# firmware image additionally needs YOUR startup code, linker script and HAL
# (e.g. from CubeMX) — see README.md.
cmake_minimum_required(VERSION 3.24)
project({{ project_name }} C CXX ASM)

set(CMAKE_C_STANDARD 11)
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

option(FITCHIP_USE_CMSIS_NN "Build ExecuTorch with the CMSIS-NN optimized kernels" {{ "ON" if use_cmsis_nn else "OFF" }})

include(FetchContent)

# Pinned tag — the executorch API/CMake surface moves between releases.
# Bump together with the `executorch` extra in FitChip's pyproject.toml.
set(EXECUTORCH_BUILD_EXECUTOR_RUNNER OFF CACHE BOOL "" FORCE)
set(EXECUTORCH_BUILD_EXTENSION_DATA_LOADER ON CACHE BOOL "" FORCE)
set(EXECUTORCH_ENABLE_LOGGING ON CACHE BOOL "" FORCE)
if(FITCHIP_USE_CMSIS_NN)
  # Consumed by executorch builds that ship Cortex-M/CMSIS-NN kernels; a
  # build without them simply ignores the flag and uses portable kernels.
  set(EXECUTORCH_BUILD_CORTEX_M ON CACHE BOOL "" FORCE)
endif()
FetchContent_Declare(
  executorch
  GIT_REPOSITORY https://github.com/pytorch/executorch.git
  GIT_TAG        {{ executorch_tag }}
)
FetchContent_MakeAvailable(executorch)

add_library({{ project_name }} STATIC
  model_pte.c
  main.cpp
)
target_include_directories({{ project_name }} PUBLIC ${CMAKE_CURRENT_SOURCE_DIR})
target_link_libraries({{ project_name }}
  PUBLIC
    executorch
    extension_data_loader
    portable_ops_lib
    portable_kernels
)

# Reference executable. Its trivial entry point is generated here and kept
# out of the library so your firmware can link the library against its own
# main(). It has no linker script: pass yours via
#   cmake -B build ... -DFITCHIP_LINKER_SCRIPT=/path/to/your.ld
file(WRITE ${CMAKE_CURRENT_BINARY_DIR}/example_main.c
  "extern int fitchip_run(void);\nint main(void) { return fitchip_run(); }\n")
add_executable({{ project_name }}_example ${CMAKE_CURRENT_BINARY_DIR}/example_main.c)
target_link_libraries({{ project_name }}_example PRIVATE {{ project_name }})
if(DEFINED FITCHIP_LINKER_SCRIPT)
  target_link_options({{ project_name }}_example PRIVATE -T${FITCHIP_LINKER_SCRIPT})
endif()
